# Paste the exact workflow-execution URL copied from
# AAVA Inspect or your working Postman request.
AAVA_WORKFLOW_URL = "https://your-aava-environment.example/workflows/workflow-executions"

# Paste the exact agent-execution URL copied from
# your successful Postman request.
AAVA_AGENT_EXECUTION_URL = "PASTE_EXACT_AGENT_EXECUTION_URL_FROM_POSTMAN"

# AAVA workflow configuration
AAVA_PIPELINE_ID = "1234"
AAVA_PRIORITY = "1"

# AAVA API bearer token
AAVA_BEARER_TOKEN = "paste-your-aava-bearer-token-here"

# AAVA user and standalone documentation agents
AAVA_USER_EMAIL = "your.name@ascendion.com"
AAVA_REPO_ANALYZER_AGENT_ID = "45881"
AAVA_PYTHON_MIGRATION_AGENT_ID = "45878"
